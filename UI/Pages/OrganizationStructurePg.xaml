<Page x:Class="RoadCompany.UI.Pages.OrganizationStructurePg"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:RoadCompany.UI.Pages"
      xmlns:uc="clr-namespace:RoadCompany.UI.UC"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="1000" 
      Title="OrganizationalStructurePg">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Border Margin="20 10 20 20" Style="{DynamicResource Borders}" Grid.Column="0">
            <Grid Background="Transparent">
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Button Grid.Row="0" Content="Road Company" FontWeight="DemiBold" Margin="15 0" x:Name="CompanyBtn" Click="CompanyBtn_Click"/>

                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Grid.Row="1" Margin="15 0 15 15">
                    <StackPanel x:Name="subdivisionContainer" Orientation="Horizontal">
                        <StackPanel.Resources>
                            <Style TargetType="{x:Type uc:StructureVw}">
                                <Setter Property="Margin" Value="0,10,0,0"/>
                            </Style>
                        </StackPanel.Resources>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Grid.Row="2" Margin="15 0 15 15">
                    <StackPanel x:Name="departmentContainer" Orientation="Horizontal">
                        <StackPanel.Resources>
                            <Style TargetType="{x:Type uc:StructureVw}">
                                <Setter Property="Margin" Value="0,10,0,0"/>
                            </Style>
                        </StackPanel.Resources>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Grid.Row="3" Margin="15 0 15 15">
                    <StackPanel x:Name="subdepartmentContainer" Orientation="Horizontal">
                        <StackPanel.Resources>
                            <Style TargetType="{x:Type uc:StructureVw}">
                                <Setter Property="Margin" Value="0,10,0,0"/>
                            </Style>
                        </StackPanel.Resources>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Margin="20 10 20 20" Style="{DynamicResource Borders}" Grid.Column="1">
            <Grid Background="Transparent">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="45"></RowDefinition>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Margin="5" Padding="5">
                    <ScrollViewer Margin="5, 10, 5, 0">
                        <StackPanel x:Name="employeeContainer">
                            <StackPanel.Resources>
                                <Style TargetType="{x:Type uc:EmployeeVw}">
                                    <Setter Property="Margin" Value="0,10,0,0"/>
                                </Style>
                            </StackPanel.Resources>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
                <Button Grid.Row="1" Content="+" FontWeight="DemiBold" Margin="10" HorizontalAlignment="Right" Width="30" Height="25" x:Name="CreateEmployeeBtn" Click="CreateEmployeeBtn_Click"/>
            </Grid>
        </Border>
    </Grid>
</Page>
