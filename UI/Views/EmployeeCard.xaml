<Window x:Class="RoadCompany.UI.Views.EmployeeCard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RoadCompany.UI.Views"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d" Title="LLC Road Company" FontFamily="Poppins"
        MinHeight="700" MinWidth="840" Height="700" Width="840" >
    <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Background="{DynamicResource WhiteColor}">
                <Border Margin="14 0 0 0" Width="50" Height="40" HorizontalAlignment="Left">
                    <Border.Background>
                        <ImageBrush ImageSource="/RoadCompany;component/Images/Logo.png" Stretch="Uniform"/>
                    </Border.Background>
                </Border>
                <TextBlock Margin="90 0 0 0" VerticalAlignment="Center" Style="{DynamicResource Title}">
                <Run Text="Employee:"/>
                <Run Text="{Binding FullNameEmp, FallbackValue='New employee:'}"/>
                </TextBlock>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,0">
                    <Button x:Name="btnEdit" Content="Edit" Margin="5" Padding="10 5" Height="35" FontSize="14"
                        Click="BtnEdit_Click" Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Reverse}"/>
                    <Button x:Name="btnSave" Content="Save" Margin="5" Padding="10 5" Height="35" FontSize="14"
                        Background="#4CAF50" Foreground="White" Click="BtnSave_Click"
                        Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Button x:Name="btnCancel" Content="Cancel" Margin="5" Padding="10 5" Height="35" FontSize="14" 
                        Background="#F44336" Foreground="White" Click="BtnCancel_Click"
                        Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Button x:Name="btnDismiss" Content="Dismiss" Margin="10 0 0 0" Padding="10 5" Height="35" FontSize="14"
                        Background="#FF9800" Foreground="White" Click="BtnDismiss_Click"
                        Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Reverse}"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                    <Border Style="{DynamicResource Borders}">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="10 10 10 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="215"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Full Name:" VerticalAlignment="Center" FontWeight="Bold"/>
                                <TextBox Grid.Column="1" 
                                     Text="{Binding FullNameEmp, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                     Style="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}, 
                                                     ConverterParameter={StaticResource ReadOnlyTextBox}}"
                                     ToolTip="{Binding Errors[FullNameEmp], FallbackValue='Required field'}"/>
                            </Grid>

                            <Grid Grid.Row="1" Margin="10 10 10 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="215"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Date of Birth:" VerticalAlignment="Center" FontWeight="Bold"/>
                                <DatePicker Grid.Column="1" 
                                       SelectedDate="{Binding BirthdayEmp, UpdateSourceTrigger=PropertyChanged}"
                                       Style="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}, 
                                                       ConverterParameter={StaticResource ReadOnlyDatePicker}}"/>
                            </Grid>

                            <Grid Grid.Row="2" Margin="10 10 10 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="215"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Mobile Phone:" VerticalAlignment="Center" FontWeight="Bold"/>
                                <TextBox Grid.Column="1" 
                                     Text="{Binding PhoneEmp, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                     Style="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}, 
                                                     ConverterParameter={StaticResource ReadOnlyTextBox}}"
                                     MaxLength="20"
                                     ToolTip="{Binding Errors[PhoneEmp], FallbackValue='Only digits and symbols +, (, ), -, spaces, # (max 20 chars)'}"/>
                            </Grid>

                            <Grid Grid.Row="3" Margin="10 10 10 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="215"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Department:" VerticalAlignment="Center" FontWeight="Bold"/>
                                <ComboBox Grid.Column="1" 
                                     ItemsSource="{Binding Departments}"
                                     SelectedItem="{Binding SelectedDepartment, UpdateSourceTrigger=PropertyChanged}"
                                     DisplayMemberPath="DepartmentName"
                                     Style="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}, 
                                                     ConverterParameter={StaticResource ReadOnlyComboBox}}"
                                     ToolTip="{Binding Errors[SelectedDepartment], FallbackValue='Required field'}"/>
                            </Grid>

                            <Grid Grid.Row="4" Margin="10 10 10 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="215"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Position:" VerticalAlignment="Center" FontWeight="Bold"/>
                                <ComboBox Grid.Column="1" 
                                     ItemsSource="{Binding Positions}"
                                     SelectedItem="{Binding SelectedPosition, UpdateSourceTrigger=PropertyChanged}"
                                     DisplayMemberPath="PositionName"
                                     Style="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}, 
                                                     ConverterParameter={StaticResource ReadOnlyComboBox}}"
                                     ToolTip="{Binding Errors[SelectedPosition], FallbackValue='Required field'}"/>
                            </Grid>

                            <Grid Grid.Row="5" Margin="10 10 10 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="215"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Immediate Supervisor:" VerticalAlignment="Center" FontWeight="Bold"/>
                                <ComboBox Grid.Column="1" 
                                     ItemsSource="{Binding AllEmployees}"
                                     SelectedItem="{Binding SelectedManager, UpdateSourceTrigger=PropertyChanged}"
                                     DisplayMemberPath="FullNameEmp"
                                     Style="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}, 
                                     ConverterParameter={StaticResource ReadOnlyComboBox}}"/>
                            </Grid>

                            <Grid Grid.Row="6" Margin="10 10 10 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="215"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Assistant:" VerticalAlignment="Center" FontWeight="Bold"/>
                                <ComboBox Grid.Column="1" 
                                     ItemsSource="{Binding AllEmployees}"
                                     SelectedItem="{Binding SelectedAssistant, UpdateSourceTrigger=PropertyChanged}"
                                     DisplayMemberPath="FullNameEmp"
                                     Style="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}, 
                                     ConverterParameter={StaticResource ReadOnlyComboBox}}"/>
                            </Grid>

                            <Grid Grid.Row="7" Margin="10 10 10 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="215"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Work Phone:" VerticalAlignment="Center" FontWeight="Bold"/>
                                <TextBox Grid.Column="1" 
                                     Text="{Binding WorkPhoneEmp, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                     Style="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}, 
                                                     ConverterParameter={StaticResource ReadOnlyTextBox}}"
                                     MaxLength="20"
                                     ToolTip="{Binding Errors[WorkPhoneEmp], FallbackValue='Required field. Only digits and symbols +, (, ), -, spaces, # (max 20 chars)'}"/>
                            </Grid>

                            <Grid Grid.Row="8" Margin="10 10 10 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="215"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Email:" VerticalAlignment="Center" FontWeight="Bold"/>
                                <TextBox Grid.Column="1" 
                                     Text="{Binding EmailEmp, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                     Style="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}, 
                                                     ConverterParameter={StaticResource ReadOnlyTextBox}}"
                                     ToolTip="{Binding Errors[EmailEmp], FallbackValue='Required field. Must be a valid email (x@x.x)'}"/>
                            </Grid>

                            <Grid Grid.Row="9" Margin="10 10 10 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="215"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Office/Desk:" VerticalAlignment="Center" FontWeight="Bold"/>
                                <TextBox Grid.Column="1" 
                                     Text="{Binding ParlorEmp, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                     Style="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}, 
                                                     ConverterParameter={StaticResource ReadOnlyTextBox}}"
                                     MaxLength="10"
                                     ToolTip="{Binding Errors[ParlorEmp], FallbackValue='Required field. Max 10 characters'}"/>
                            </Grid>

                            <Grid Grid.Row="10" Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="215"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Additional Info:" VerticalAlignment="Top" FontWeight="Bold" Margin="0,5,0,0"/>
                                <TextBox Grid.Column="1" 
                                     Text="{Binding AdditionalInfoEmp, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}, 
                                                     ConverterParameter={StaticResource ReadOnlyTextBox}}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     Height="60"
                                     VerticalScrollBarVisibility="Auto"/>
                            </Grid>

                            <Border Grid.Row="11" Background="#FFF8E1" BorderBrush="#FF9800" BorderThickness="1" 
                                Visibility="{Binding HasErrors, Converter={StaticResource BooleanToVisibilityConverter}}" 
                                Margin="0,10,0,0" Padding="10">
                                <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF5722" TextWrapping="Wrap"/>
                            </Border>
                        </Grid>
                    </Border>
                </ScrollViewer>

                <Grid Grid.Column="1" Margin="10 5 5 0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{DynamicResource Borders}" Margin="0 0 0 10">
                        <StackPanel>
                            <TextBlock Text="Employee Events" FontWeight="Bold" Margin="0 0 0 10"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <CheckBox Content="Past" IsChecked="{Binding ShowPastEvents}" Margin="0,0,10,0"/>
                                <CheckBox Content="Current" IsChecked="{Binding ShowCurrentEvents}" Margin="0,0,10,0"/>
                                <CheckBox Content="Future" IsChecked="{Binding ShowFutureEvents}" Margin="0,0,10,0"/>
                            </StackPanel>

                            <Button Content="Add Event" Click="BtnAddEvent_Click" 
                                HorizontalAlignment="Stretch" Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Margin="0 5" Style="{DynamicResource Borders}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ListView Grid.Row="0" ItemsSource="{Binding EmployeeEvents}" 
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  BorderThickness="0" Padding="0"
                  HorizontalContentAlignment="Stretch">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </ListView.ItemContainerStyle>

                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" Text="{Binding TypeIcon}" FontSize="16" 
                                       Margin="0,0,10,0" VerticalAlignment="Top"/>

                                                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                                    <TextBlock Text="{Binding EventType}" FontWeight="Bold" FontSize="14"/>
                                                    <TextBlock Text="{Binding DateRange}" FontSize="12" Foreground="#666" Margin="0,2,0,0"/>
                                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" 
                                           FontSize="12" Margin="0,5,0,0"/>
                                                </StackPanel>

                                                <Button Grid.Column="2" Content="✕" FontSize="12" Padding="5,2" 
                                    MinWidth="30" Height="27"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Click="DeleteEvent_Click" Tag="{Binding}"
                                    Visibility="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=Window}, 
                                            Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>

                                <ListView.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.HeaderTemplate>
                                            <DataTemplate>
                                                <Border Background="#E3F2FD" Padding="10,5" Margin="0,10,0,5">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"/>
                                                </Border>
                                            </DataTemplate>
                                        </GroupStyle.HeaderTemplate>
                                    </GroupStyle>
                                </ListView.GroupStyle>
                            </ListView>

                            <TextBlock Grid.Row="0" Text="No events" HorizontalAlignment="Center" 
                   VerticalAlignment="Center" Foreground="#999" FontStyle="Italic"
                   Visibility="{Binding HasEvents, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Reverse}"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Window>
