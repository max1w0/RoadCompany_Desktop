<Window x:Class="RoadCompany.UI.Views.MainWnd"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RoadCompany.UI.Views"
        mc:Ignorable="d" Name="home" Title="LLC Road Company" 
        MinHeight="600" MinWidth="950" Height="600" Width="950">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{DynamicResource WhiteColor}">
            <Border Margin="14 0 0 0" Width="50" Height="40" HorizontalAlignment="Left">
                <Border.Background>
                    <ImageBrush ImageSource="/RoadCompany;component/Images/Logo.png" Stretch="Uniform"/>
                </Border.Background>
            </Border>
            <TextBlock Margin="90 0 0 0" Height="35" Width="250" Style="{DynamicResource Title}">Organizational Structure</TextBlock>
        </Grid>

        <Frame Grid.Row="1" x:Name="MainFrm" Margin="10" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
