<Window x:Class="RoadCompany.UI.Views.AddEventDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RoadCompany.UI.Views"
        mc:Ignorable="d" MinHeight="400" MinWidth="400"
        Title="Add Event" Height="400" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Event Type:" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" x:Name="cmbEventType" SelectedValue="{Binding EventType}">
                <ComboBoxItem Content="Training"/>
                <ComboBoxItem Content="Absence"/>
                <ComboBoxItem Content="Vacation"/>
                <ComboBoxItem Content="Time Off"/>
            </ComboBox>
        </Grid>

        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Start Date:" VerticalAlignment="Center"/>
            <DatePicker Grid.Column="1" x:Name="dpStartDate" SelectedDate="{Binding StartDate}"/>
        </Grid>

        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="End Date:" VerticalAlignment="Center"/>
            <DatePicker Grid.Column="1" x:Name="dpEndDate" SelectedDate="{Binding EndDate}"/>
        </Grid>

        <Grid Grid.Row="3" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Description:" VerticalAlignment="Top" Margin="0,5,0,0"/>
            <TextBox Grid.Column="1" x:Name="txtDescription" 
                     Text="{Binding Description}" 
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Height="60"
                     VerticalScrollBarVisibility="Auto"/>
        </Grid>

        <Border Grid.Row="4" Background="#FFF8E1" BorderBrush="#FF9800" BorderThickness="1" 
                Margin="0,0,0,10" Padding="10" Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF5722" TextWrapping="Wrap"/>
        </Border>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
            <Button Content="Add" Width="80" Margin="0,0,10,0" Click="BtnAdd_Click"/>
            <Button Content="Cancel" Width="80" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>